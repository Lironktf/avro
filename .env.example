# Base RPC. Sugar SDK reads this via SUGAR_RPC_URI_8453.
SUGAR_RPC_URI_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Your veAERO NFT id (optional for V1 — you can pass --power instead).
VENFT_ID=

# Display-only: amount of veAERO to simulate if VENFT_ID is empty.
SIMULATED_VEAERO_POWER=100
